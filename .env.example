# Source Maven repository
# Must expose directory-listing HTML pages (Nexus 2/3, Apache httpd autoindex, etc.)
ADVISOR_MAVEN_SOURCE_URL=https://your-source-nexus/repository/your-repo/
ADVISOR_MAVEN_SERVER_USERNAME=
ADVISOR_MAVEN_SERVER_PASSWORD=

# Target Maven repository
# Use the 'nexus' service hostname (not localhost) when running inside Docker
TARGET_MAVEN_URL=http://nexus:8081/repository/maven-releases/
TARGET_MAVEN_USERNAME=admin
TARGET_MAVEN_PASSWORD=

# Schedule for Ofelia — use Go duration syntax to avoid ambiguity with
# Ofelia's second-precision 6-field cron parser:
#   "@every 30m"  — every 30 minutes
#   "@every 1h"   — every hour
#   "@every 24h"  — daily
# If using 6-field cron, remember field 1 is seconds: "0 0 2 * * *" = daily at 02:00
# Note: source.root-url and target.root-url must have matching path depth —
# see README for details.
SCHEDULE=@every 1h

# --- Performance tuning (all optional, defaults shown) ---

# Max concurrent HTTP requests for scraper and publisher
SYNC_SCRAPER_MAX_CONCURRENT=6
SYNC_PUBLISHER_MAX_CONCURRENT=8

# Per-request delay in ms (set to 0 to disable throttling)
SYNC_SCRAPER_FILE_DELAY_MS=500
SYNC_SCRAPER_DIRECTORY_DELAY_MS=1000
SYNC_PUBLISHER_FILE_DELAY_MS=1000

# Smart sync: skip artifacts that already exist on target (HEAD check)
SYNC_PUBLISHER_SKIP_EXISTING=true
SYNC_PUBLISHER_VERIFY_SIZE=true

# Retry on transient failures (IOException, HTTP 5xx)
SYNC_RETRY_MAX_ATTEMPTS=3
SYNC_RETRY_BACKOFF_BASE_MS=1000
